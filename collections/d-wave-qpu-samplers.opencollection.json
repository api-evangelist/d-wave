{
  "opencollection": "1.0.0",
  "info": {
    "name": "D-Wave QPU Samplers (Advantage / Advantage2)",
    "version": "3.0"
  },
  "request": {
    "auth": {
      "type": "apikey",
      "key": "X-Auth-Token",
      "value": "{{X-Auth-Token}}",
      "placement": "header"
    }
  },
  "items": [
    {
      "info": {
        "name": "QPU",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Submit QPU Problem",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://cloud.dwavesys.com/sapi/v2/problems/",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Submit an Ising or QUBO problem to a D-Wave QPU sampler."
        }
      ]
    }
  ],
  "bundled": true
}